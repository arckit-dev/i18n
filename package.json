{
  "name": "@arckit/i18n",
  "version": "1.1.0",
  "description": "Internationalization with i18next, language detection, and React provider support",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "author": "Marc Gavanier <marc@gavanier.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/arckit-dev/i18n.git"
  },
  "homepage": "https://github.com/arckit-dev/i18n#readme",
  "bugs": {
    "url": "https://github.com/arckit-dev/i18n/issues"
  },
  "keywords": ["arckit", "i18n", "i18next", "internationalization", "language-detection", "react"],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    },
    "./detectors": {
      "import": {
        "types": "./dist/detectors.d.ts",
        "default": "./dist/detectors.js"
      },
      "require": {
        "types": "./dist/detectors.d.cts",
        "default": "./dist/detectors.cjs"
      }
    },
    "./resource-loader/node": {
      "import": "./dist/resource-loader.node.js",
      "require": "./dist/resource-loader.node.cjs"
    },
    "./resource-loader/fetch": {
      "import": "./dist/resource-loader.fetch.js",
      "require": "./dist/resource-loader.fetch.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "client": ["dist/client.d.ts"],
      "detectors": ["dist/detectors.d.ts"],
      "resource-loader/node": ["dist/resource-loader.node.d.ts"],
      "resource-loader/fetch": ["dist/resource-loader.fetch.d.ts"]
    }
  },
  "files": ["dist"],
  "sideEffects": ["./dist/resource-loader.node.*", "./dist/resource-loader.fetch.*"],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint:code": "biome check --write",
    "lint:code:ci": "biome ci",
    "lint:commit": "commitlint --from origin/main",
    "lint:unused": "knip",
    "check:publint": "publint",
    "check:attw": "attw --pack .",
    "check:size": "size-limit",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "peerDependencies": {
    "i18next": ">=25",
    "react": ">=19",
    "react-i18next": ">=16"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@biomejs/biome": "^2.4.0",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/exec": "^7.0.0",
    "@semantic-release/git": "^10.0.0",
    "@size-limit/file": "^11.0.0",
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "husky": "^9.0.0",
    "i18next": "^25.0.0",
    "knip": "^5.0.0",
    "lint-staged": "^16.0.0",
    "piqure": "^2.2.0",
    "publint": "^0.3.0",
    "react": "^19.0.0",
    "react-i18next": "^16.0.0",
    "semantic-release": "^24.0.0",
    "size-limit": "^11.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "3 kB"
    }
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
